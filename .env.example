# ─── Supabase (Service-Role, NICHT anon — RLS-bypass nötig zum Schreiben) ───
SUPABASE_URL=https://gkpdoxerrcuqaiwvekfy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Anthropic API ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── ScrapingFish (Residential-Proxy fuer eBay-Akamai-Bypass) ──────────────
# eBay/Akamai blockt Hetzner-Datacenter-IPs hart. ScrapingFish routet ueber
# Residential-IPs. Account anlegen: https://scrapingfish.com
SCRAPINGFISH_API_KEY=...

# ─── Cardmarket-Account (wird nur fuer das initial-Login-Skript genutzt;
#     der Agent selbst nutzt nur die Browser-Cookies aus playwright-state/)
#     ──────────────────────────────────────────────────────────────────────
# Optional — kann leer bleiben, weil der Login interaktiv passiert.
CM_USERNAME=
CM_PASSWORD=

# eBay-Sold-Listings sind public — KEIN Login noetig.

# ─── Service-Konfiguration ────────────────────────────────────────────────
PORT=8080
CRON_SCHEDULE=30 6 * * *
CRON_TIMEZONE=Europe/Berlin

# Bevorzugte Verkäufer für PSA10-Pricing (Reihenfolge = Priorität)
PSA10_PREFERRED_SELLERS=probstin123,dcsports87

# eBay-Filter
EBAY_MIN_PRICE_USD=700
EBAY_SEARCH_TERM=One Piece PSA 10

# Versand-Konstanten für Cardmarket-EK-Berechnung (€)
SHIPPING_DE_EUR=10
SHIPPING_EU_MIN_EUR=20
SHIPPING_EU_MAX_EUR=40

# Daten-Quality-Schwelle: Faktor zwischen erwartetem und neuem Preis,
# ab dem ein Verdacht generiert wird
DQ_PRICE_MISMATCH_FACTOR=3
