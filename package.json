{
  "name": "gradetracker-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daily-Run-Service: scraped eBay + Cardmarket, befuellt den Einkaufsplan in GradeTracker, sammelt Daten-Quality-Verdachtsfaelle.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
